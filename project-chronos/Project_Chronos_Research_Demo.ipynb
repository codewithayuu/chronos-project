   "metadata": {},
   "source": [
    "## Hero Case 1: \"Silent Sepsis\" - Entropy Drops 4+ Hours Before Crisis\n",
    "\n",
    "This demonstrates Chronos' core capability: detecting deterioration when traditional monitors show normal values."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Generate Hero Case 1: Silent Sepsis\n",
    "base_time = datetime(2024, 1, 15, 8, 0, 0)\n",
    "rng = np.random.RandomState(42)\n",
    "\n",
    "hero1 = DataGenerator.hero_case_1(base_time, rng)\n",
    "print(f\"📋 {hero1.name}\")\n",
    "print(f\"   📝 {hero1.description}\")\n",
    "print(f\"   ⏱️  Duration: {hero1.duration_minutes} minutes\")\n",
    "print(f\"   💊 Drug Events: {len(hero1.drug_events)}\")\n",
    "print(f\"   📊 Vital Records: {len(hero1.records)}\")\n",
    "\n",
    "# Show key drug events\n",
    "for event in hero1.drug_events:\n",
    "    print(f\"   💊 Minute {event.minute}: {event.drug_name} ({event.dose} {event.unit})\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Process Hero Case 1 through the pipeline\n",
    "replay = ReplayService(pipeline, config)\n",
    "replay.load_cases([hero1])\n",
    "\n",
    "ces_values = []\n",
    "timestamps = []\n",
    "hr_values = []\n",
    "alert_severities = []\n",
    "\n",
    "print(\"🔄 Processing Hero Case 1 through pipeline...\")\n",
    "\n",
    "# Process first 600 minutes (10 hours)\n",
    "for minute in range(600):\n",
    "    replay.tick()\n",
    "    \n",
    "    state = pipeline.get_patient_state(\"BED-01\")\n",
    "    if state and not state.calibrating:\n",
    "        ces_values.append(state.composite_entropy)\n",
    "        timestamps.append(state.timestamp)\n",
    "        hr_values.append(state.vitals.heart_rate.value)\n",
    "        alert_severities.append(state.alert.severity.value)\n",
    "    \n",
    "    # Print key milestones\n",
    "    if minute == 300:\n",
    "        print(f\"   ⏰ Minute 300: Entropy transition begins\")\n",
    "    elif minute == 520:\n",
    "        print(f\"   ⚠️  Minute 520: Vitals start shifting\")\n",
    "    elif minute == 580:\n",
    "        print(f\"   🚨 Minute 580: Overt deterioration begins\")\n",
    "\n",
    "print(f\"✅ Processed {len(ces_values)} data points\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create comprehensive visualization\n",
    "fig, axes = plt.subplots(4, 1, figsize=(15, 12))\n",
    "fig.suptitle('Hero Case 1: \"Silent Sepsis\" - Entropy vs Traditional Monitoring', fontsize=16, fontweight='bold')\n",
    "\n",
    "# Plot 1: Composite Entropy Score\n",
    "ax1 = axes[0]\n",
    "ax1.plot(timestamps, ces_values, 'b-', linewidth=2, label='Composite Entropy Score')\n",
    "ax1.axhline(y=0.6, color='g', linestyle='--', alpha=0.7, label='Normal Threshold')\n",
    "ax1.axhline(y=0.4, color='orange', linestyle='--', alpha=0.7, label='Watch Threshold')\n",
    "ax1.axhline(y=0.2, color='r', linestyle='--', alpha=0.7, label='Warning Threshold')\n",
    "ax1.fill_between(timestamps, 0.4, 1, where=np.array(ces_values) >= 0.4, alpha=0.2, color='green', label='Safe Zone')\n",
    "ax1.fill_between(timestamps, 0, 0.4, where=np.array(ces_values) < 0.4, alpha=0.2, color='red', label='Danger Zone')\n",
    "ax1.set_ylabel('Composite Entropy Score', fontsize=12)\n",
    "ax1.set_title('🧠 Entropy-Based Early Warning', fontsize=14, fontweight='bold')\n",
    "ax1.legend(loc='upper right')\n",
    "ax1.grid(True, alpha=0.3)\n",
    "ax1.set_ylim(0, 1)\n",
    "\n",
    "# Plot 2: Heart Rate\n",
    "ax2 = axes[1]\n",
    "ax2.plot(timestamps, hr_values, 'r-', linewidth=2, label='Heart Rate')\n",
    "ax2.axhline(y=100, color='orange', linestyle='--', alpha=0.7, label='Tachycardia Threshold')\n",
    "ax2.axhline(y=60, color='blue', linestyle='--', alpha=0.7, label='Bradycardia Threshold')\n",
    "ax2.fill_between(timestamps, 60, 100, alpha=0.1, color='green', label='Normal Range')\n",
    "ax2.set_ylabel('Heart Rate (bpm)', fontsize=12)\n",
    "ax2.set_title('❤️ Traditional Heart Rate Monitoring', fontsize=14, fontweight='bold')\n",
    "ax2.legend(loc='upper right')\n",
    "ax2.grid(True, alpha=0.3)\n",
    "\n",
    "# Plot 3: Alert Severity Timeline\n",
    "ax3 = axes[2]\n",
    "severity_colors = {'NONE': 'green', 'WATCH': 'orange', 'WARNING': 'red', 'CRITICAL': 'darkred'}\n",
    "severity_levels = [severity_colors.get(s, 'gray') for s in alert_severities]\n",
    "ax3.scatter(timestamps, [1]*len(alert_severities), c=severity_levels, s=50, alpha=0.8)\n",
    "ax3.set_ylabel('Alert Level', fontsize=12)\n",
    "ax3.set_title('🚨 Alert Severity Timeline', fontsize=14, fontweight='bold')\n",
    "ax3.set_ylim(0.5, 1.5)\n",
    "ax3.set_yticks([1])\n",
    "ax3.set_yticklabels(['ALERT'])\n",
    "ax3.grid(True, alpha=0.3)\n",
    "\n",
    "# Plot 4: Key Milestones\n",
    "ax4 = axes[3]\n",
    "milestones = [\n",
    "    (300, \"Entropy Transition Begins\"),\n",
    "    (520, \"Vitals Start Shifting\"),\n",
    "    (580, \"Overt Deterioration\")\n",
    "]\n",
    "\n",
    "for minute, label in milestones:\n",
    "    milestone_time = base_time + timedelta(minutes=minute)\n",
    "    ax4.axvline(x=milestone_time, color='red', linestyle='--', alpha=0.7)\n",
    "    ax4.text(milestone_time, 1.5, label, rotation=90, va='bottom', fontsize=10, fontweight='bold')\n",
    "\n",
    "ax4.set_ylabel('Timeline', fontsize=12)\n",
    "ax4.set_title('📅 Key Clinical Milestones', fontsize=14, fontweight='bold')\n",
    "ax4.set_ylim(0, 2)\n",
    "ax4.set_yticks([])\n",
    "ax4.grid(True, alpha=0.3)\n",
    "\n",
    "# Format x-axis for all plots\n",
    "for ax in axes:\n",
    "    ax.set_xlabel('Time', fontsize=12)\n",
    "    ax.tick_params(axis='x', rotation=45)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Key findings\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"🔍 KEY FINDINGS - Silent Sepsis Detection\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "# Find when entropy first drops below threshold\n",
    "entropy_drop_time = None\n",
    "for i, ces in enumerate(ces_values):\n",
    "    if ces < 0.4:  # Watch threshold\n",
    "        entropy_drop_time = timestamps[i]\n",
    "        break\n",
    "\n",
    "# Find when HR first exceeds tachycardia\n",
    "hr_crisis_time = None\n",
    "for i, hr in enumerate(hr_values):\n",
    "    if hr > 100:  # Tachycardia threshold\n",
    "        hr_crisis_time = timestamps[i]\n",
    "        break\n",
    "\n",
    "if entropy_drop_time and hr_crisis_time:\n",
    "    lead_time = (hr_crisis_time - entropy_drop_time).total_seconds() / 3600\n",
    "    print(f\"🧠 Entropy Alert:    {entropy_drop_time.strftime('%H:%M')}\")\n",
    "    print(f\"❤️  HR Crisis:        {hr_crisis_time.strftime('%H:%M')}\")\n",
    "    print(f\"⏰ Lead Time:        {lead_time:.1f} hours\")\n",
    "    print(f\"🎯 Result:           Chronos detected deterioration {lead_time:.1f} hours before traditional monitors!\")\n",
    "else:\n",
    "    print(\"⚠️  Could not determine lead time in this dataset\")"
   ]
